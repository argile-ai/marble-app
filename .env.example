# StreamVGGT Modal WebSocket endpoint
# After deploying with `modal deploy backend/modal_app.py`, set this to the
# WebSocket URL from the deployment output (replace https:// with wss://)
VITE_STREAMVGGT_WS_URL=wss://your-modal-deployment.modal.run/ws

# SpatialLM Modal endpoint for floor plan generation
# After deploying with `modal deploy backend/spatiallm_app.py`
VITE_SPATIALLM_URL=https://your-modal-deployment.modal.run
